{
  "permissions": {
    "allow": [
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)"
    ]
  },
  "enabledPlugins": {
    "prisma@claude-plugins-official": true
  }
}
